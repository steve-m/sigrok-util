diff --git a/src/libsigrok-internal.h b/src/libsigrok-internal.h
index 8d509eb..3a72a30 100644
--- a/src/libsigrok-internal.h
+++ b/src/libsigrok-internal.h
@@ -1129,8 +1129,19 @@ static inline void write_dblle_inc(uint8_t **p, double x)
 
 #ifdef __APPLE__
 #define SR_DRIVER_LIST_SECTION "__DATA,__sr_driver_list"
+#define SR_DRIVER_LIST_SECTION_HEAD SR_DRIVER_LIST_SECTION
+#define SR_DRIVER_LIST_SECTION_TAIL SR_DRIVER_LIST_SECTION
+#elif defined(_WIN32) || defined(__CYGWIN__)
+/* COFF section $-suffix ordering: the linker merges sections with the
+ * same prefix and sorts them alphabetically by suffix. This guarantees
+ * start < drivers < stop without needing ld -r (which lld lacks for COFF). */
+#define SR_DRIVER_LIST_SECTION "__sr_driver_list$m"
+#define SR_DRIVER_LIST_SECTION_HEAD "__sr_driver_list$a"
+#define SR_DRIVER_LIST_SECTION_TAIL "__sr_driver_list$z"
 #else
 #define SR_DRIVER_LIST_SECTION "__sr_driver_list"
+#define SR_DRIVER_LIST_SECTION_HEAD SR_DRIVER_LIST_SECTION
+#define SR_DRIVER_LIST_SECTION_TAIL SR_DRIVER_LIST_SECTION
 #endif
 
 #if !defined SR_DRIVER_LIST_NOREORDER && defined __has_attribute
