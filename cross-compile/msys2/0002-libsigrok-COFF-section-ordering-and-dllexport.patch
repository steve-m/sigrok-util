diff --git a/configure.ac b/configure.ac
index 024dd4d..dc5fbcc 100644
--- a/configure.ac
+++ b/configure.ac
@@ -41,6 +41,14 @@ AC_PROG_CXX
 AC_PROG_INSTALL
 AC_PROG_LN_S
 
+# Check for Windows target (needed for driver list linking strategy).
+# On Windows/COFF, we use section $-suffix ordering instead of ld -r.
+case $host_os in
+  mingw* | cygwin* | msys*) is_windows=yes ;;
+  *) is_windows=no ;;
+esac
+AM_CONDITIONAL([WINDOWS], [test "x$is_windows" = "xyes"])
+
 # Required for per-target flags or subdir-objects with C sources.
 AM_PROG_CC_C_O
 
