diff --git a/Makefile.am b/Makefile.am
index 3b68142..3608eda 100644
--- a/Makefile.am
+++ b/Makefile.am
@@ -221,6 +221,9 @@ libsigrok_la_SOURCES += \
 noinst_LTLIBRARIES = src/libdrivers.la \
 	src/libdrivers_head.la src/libdrivers_tail.la
 
+if !WINDOWS
+# On non-Windows (ELF/Mach-O), use ld -r to merge driver list sections
+# in the correct order (head, drivers, tail).
 src/libdrivers.o: src/libdrivers.la \
 		src/libdrivers_head.la src/libdrivers_tail.la
 	$(AM_V_CCLD)$(LINK) src/libdrivers_head.la src/libdrivers.la \
@@ -229,6 +232,7 @@ src/libdrivers.lo: src/libdrivers.o
 	$(AM_V_GEN)echo "# Generated by libtool" > $@
 	$(AM_V_at)echo "pic_object='libdrivers.o'" >> $@
 	$(AM_V_at)echo "non_pic_object='libdrivers.o'" >> $@
+endif
 
 src_libdrivers_head_la_SOURCES = src/driver_list_start.c
 
@@ -778,7 +782,14 @@ src_libdrivers_la_SOURCES += \
 	src/hardware/zketech-ebd-usb/api.c
 endif
 
+if WINDOWS
+# On Windows/COFF, section $-suffix ordering (__sr_driver_list$a/$m/$z)
+# guarantees correct driver list layout without ld -r (which lld lacks).
+libsigrok_la_LIBADD = src/libdrivers_head.la src/libdrivers.la \
+	src/libdrivers_tail.la $(SR_EXTRA_LIBS) $(LIBSIGROK_LIBS)
+else
 libsigrok_la_LIBADD = src/libdrivers.lo $(SR_EXTRA_LIBS) $(LIBSIGROK_LIBS)
+endif
 libsigrok_la_LDFLAGS = -version-info $(SR_LIB_VERSION) -no-undefined
 
 library_includedir = $(includedir)/libsigrok
