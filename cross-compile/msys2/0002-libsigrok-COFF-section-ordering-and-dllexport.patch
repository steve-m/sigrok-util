@@ -29,6 +29,6 @@
 
 SR_PRIV const struct sr_dev_driver *sr_driver_list__stop[]
 	SR_DRIVER_LIST_NOREORDER
-	__attribute__((section (SR_DRIVER_LIST_SECTION),
+	__attribute__((section (SR_DRIVER_LIST_SECTION_TAIL),
